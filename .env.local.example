# ─────────────────────────────────────────────────────────────
# Tally environment variables — copy to `.env.local`.
# Firebase is REQUIRED (Google sign-in). The rest are optional.
# ─────────────────────────────────────────────────────────────

# Firebase — Google authentication. REQUIRED.
# Create a project at https://console.firebase.google.com,
# add a Web App, enable Google as a sign-in provider, then paste:
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# MongoDB Atlas — the data store (server-side only, never exposed to client).
# REQUIRED. Allow Vercel/your IP in Atlas Network Access (0.0.0.0/0 for Vercel).
MONGODB_URI=

# Public base URL of the deployment (e.g. https://tally.app). Used to build
# invite links from a trusted origin instead of the spoofable request header.
# Falls back to the request origin when unset. Set this in production.
NEXT_PUBLIC_APP_URL=

# Email (invites + EMI receipts) — sent via Gmail SMTP with Nodemailer.
# Create an App Password: Google Account → Security → 2-Step Verification →
# App passwords. Without these, emails are skipped (in-app links still work).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=

# Web Push notifications (optional). Generate with:
#   npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Secret for the daily EMI cron (/api/cron/emi). Any long random string.
CRON_SECRET=
